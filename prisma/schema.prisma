generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  authUserId String   @unique // THIS IS THE BRIDGE: The MongoDB User ID goes here!
  email      String   @unique
  name       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  resumes    Resume[] // A user can have many resumes
}

model Resume {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @default("My Resume")
  content   String?  // JSON or text data
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}